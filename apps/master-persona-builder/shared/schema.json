{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["meta", "master"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["slug", "name", "description"],
      "properties": {
        "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "master": {
      "type": "object",
      "required": ["display_name"],
      "properties": {
        "display_name": { "type": "string" }
      }
    }
  }
}
